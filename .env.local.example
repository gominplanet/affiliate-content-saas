# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# WordPress / Hostinger
WORDPRESS_API_URL=https://yourdomain.com/wp-json/wp/v2
WORDPRESS_APP_PASSWORD=your-app-password
HOSTINGER_API_KEY=your-hostinger-api-key

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — Resend (transactional sender for app-level emails)
# Supabase Auth emails go through a separate Custom SMTP setting in the
# Supabase dashboard, using these same Resend credentials. See EMAIL_SETUP.md.
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=MVP Affiliate <noreply@mvpaffiliate.io>
