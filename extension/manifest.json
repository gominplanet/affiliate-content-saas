{
  "manifest_version": 3,
  "key": "",
  "name": "SCOUT \u2014 MVP Affiliate",
  "version": "1.11.10",
  "description": "Companion for MVP Affiliate: grabs real YouTube frames for sharper thumbnails and reads Amazon product details.",
  "homepage_url": "https://www.mvpaffiliate.io",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://affiliate-program.amazon.com/*",
    "https://www.amazon.com/creatorconnections/*",
    "https://www.amazon.com/manage-content*",
    "https://www.amazon.com/shop/*",
    "https://www.mvpaffiliate.io/*",
    "https://*.youtube.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://mvpaffiliate.io/*",
      "https://*.mvpaffiliate.io/*",
      "http://localhost:3000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "SCOUT \u2014 MVP Affiliate",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://affiliate-program.amazon.com/*",
        "https://www.amazon.com/creatorconnections/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
